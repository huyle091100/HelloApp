<p style="color: green"><%= notice %></p>

<% content_for :title, "Microposts" %>

<h1>Microposts</h1>

<div id="microposts">
  <table>
    <tr>
      <th>Content</th>
      <th>User</th>
    </tr>
  </table>
  <% @microposts.each do |micropost| %>
    <%= render micropost %>
  <% end %>
</div>

<%= link_to "New micropost", new_micropost_path %>
